# ✅ Plantilla de variables de entorno
# Copia este archivo como .env en tu máquina local y completa con tus datos
# Este archivo SÍ se sube a GitHub (sin valores reales)

# Firebase Configuration
# Obtén estos valores del Firebase Console: https://console.firebase.google.com
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

# AWS Configuration (para Vercel Functions)
# Obtén estos valores de AWS IAM Console
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_REGION=us-east-1
AWS_SES_EMAIL=
